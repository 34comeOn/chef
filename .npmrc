# Required for React Native/Metro bundler to resolve workspace packages.
# Metro cannot traverse pnpm symlinks; hoisting makes deps available as if
# they were installed normally. Do not remove or modify these patterns.
node-linker=hoisted
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=@react-navigation/*
